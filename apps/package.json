{
  "name": "codexmanager-frontend",
  "version": "0.1.10",
  "packageManager": "pnpm@10.30.3",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:desktop": "next dev --webpack -p 3005",
    "build": "next build",
    "build:desktop": "next build",
    "tauri:dev": "corepack pnpm dlx @tauri-apps/cli@2.10.1 dev",
    "tauri:build": "corepack pnpm dlx @tauri-apps/cli@2.10.1 build",
    "tauri:build:windows": "node -e \"if(process.platform!=='win32'){console.error('tauri:build:windows 需要在 Windows 主机上执行，或使用 GitHub Actions 的 windows-latest runner。当前平台: '+process.platform);process.exit(1)}\" && corepack pnpm dlx @tauri-apps/cli@2.10.1 build --bundles nsis",
    "tauri:build:linux": "corepack pnpm dlx @tauri-apps/cli@2.10.1 build --bundles appimage,deb",
    "tauri:build:linux:appimage": "corepack pnpm dlx @tauri-apps/cli@2.10.1 build --bundles appimage",
    "tauri:build:linux:deb": "corepack pnpm dlx @tauri-apps/cli@2.10.1 build --bundles deb",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tanstack/react-query": "^5.90.21",
    "@tauri-apps/api": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
